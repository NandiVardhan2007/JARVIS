# ════════════════════════════════════════════════════════════
#  JARVIS — Environment Configuration
#  Copy this file to .env and fill in your credentials.
#  No OpenAI key required.
# ════════════════════════════════════════════════════════════

# ── LiveKit (required) ────────────────────────────────────────
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# ── Groq (primary AI — LLM + STT + TTS) ─────────────────────
# Get free key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key

# ── Cartesia (primary TTS) ──────────────────────────────────
CARTESIA_API_KEY=your_cartesia_api_key
CARTESIA_VOICE_ID=your_cloned_voice_id

# ── NVIDIA NIM (fallback AI — LLM + STT + TTS) ──────────────
# Get key at: https://build.nvidia.com
NVIDIA_API_KEY=your_nvidia_api_key

# ── Model overrides (optional) ───────────────────────────────
# LLM
JARVIS_LLM_MODEL=llama-3.3-70b-versatile
JARVIS_NIM_LLM_MODEL=meta/llama-3.3-70b-instruct

# STT
JARVIS_STT_MODEL=whisper-large-v3

# TTS — Groq Orpheus voices: daniel, austin, troy, autumn, diana, hannah
JARVIS_TTS_VOICE=daniel

# ── Email (optional — for send_email tool) ───────────────────
JARVIS_EMAIL=your_gmail@gmail.com
JARVIS_EMAIL_PASSWORD=your_gmail_app_password

# ── YouTube Data API (optional — improves play_media) ────────
YOUTUBE_API_KEY=your_youtube_api_key

# ── IoT — ESP32 bulb IP (optional) ───────────────────────────
JARVIS_ESP32_IP=10.216.226.11

# ── Screen reader — Gemini Vision (optional) ──────────────────
# Primary vision model for read_screen tool.
# Get key at: https://aistudio.google.com
# Falls back to Groq vision (llama-4-scout) if not set.
GEMINI_API_KEY=your_gemini_api_key

# ── Telegram Bot (optional — for send/read Telegram) ─────────
# 1. Open Telegram → search @BotFather → /newbot
# 2. Copy the token here.
# 3. The recipient must /start your bot first.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# ── Discord (optional — choose one or both) ───────────────────
# Option A — Webhook (single channel, no bot needed):
#   Server Settings → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Option B — Bot token (multi-channel, read + write):
#   https://discord.com/developers/applications → New App → Bot → Reset Token
#   Scopes: bot  |  Permissions: Send Messages, Read Message History
DISCORD_BOT_TOKEN=your_discord_bot_token
TELEGRAM_LLM_API=

# ── GitHub (optional — for github_tool) ──────────────────────
# Generate a Personal Access Token at https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token

# ── Sub-Agent LLM Keys (dedicated per agent) ─────────────────
EMAIL_AGENT_LLM_API=your_email_agent_nim_api_key
SCRAPER_AGENT_LLM_API=your_scraper_agent_nim_api_key
